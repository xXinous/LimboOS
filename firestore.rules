rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "gm.mpg@runningman.local";
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }
    function isValidPayloadSize() {
      return request.resource.data.keys().size() < 50; 
    }

    // Regras de Campanhas - Crítico para a tela de seleção
    match /campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /qrRedirects/{redirectId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /{path=**}/achievements/{achId} {
      allow read: if isAdmin();
    }
    match /{path=**}/stats/{statDoc} {
      allow read: if isAdmin();
    }
    match /system/gameEvents {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /system/limboState {
      allow read: if true;
      allow update: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /system/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastLogin', 'spotifyPlaylistUrl', 'forceTerminalOpen', 'forceMacOpen', 'campaignId']));
      allow delete: if isAdmin();
      match /tapes/{tapeId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      match /achievements/{achId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
      match /stats/{statDoc} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if (isOwner(userId) && isValidPayloadSize()) || isAdmin();
      }
      match /gallery/{imageId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isAdmin();
      }
    }
    match /audios/{audioId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /gallery/{imageId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /groups/{groupId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /jukeboxTracks/{trackId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    match /playEvents/{eventId} {
      allow read: if isAdmin();
      allow create: if isOwner(request.resource.data.uid) && isValidPayloadSize();
      allow update, delete: if isAdmin();
    }
    match /activityLog/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
